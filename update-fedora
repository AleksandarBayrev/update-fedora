#!/bin/bash
# Script to update Fedora systems
# Ensure the script is run with root privileges

if [ "$(id -u)" != "0" ];
then
   echo "This script must be run as root. Try 'sudo update-fedora'" 1>&2
   exit 1
fi

# Distribution checks
distroCheckOne=`cat /etc/os-release | grep -i "NAME=\"Fedora Linux\""`
distroCheckTwo=`cat /etc/fedora-release | grep -i "Fedora release"`

if [[ -z $distroCheckOne || -z $distroCheckTwo ]]
then
    echo "Distribution is not Fedora, exiting..."
    exit 0
fi

echo 'Performing system update'

dnf clean all
dnf offline clean
dnf offline-upgrade clean
dnf offline-upgrade download -y --refresh

if command -v flatpak &> /dev/null
then
    echo 'Performing flatpaks update'
    flatpak update -y
fi

dnf offline reboot
